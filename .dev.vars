# Local dev secrets — mirrors Cloudflare environment variables
# DO NOT commit this file (it's in .gitignore)
DISCORD_WEBHOOK_URL=URL_1,URL_2  # Supports multiple webhooks separated by commas
DISCORD_BOT_TOKEN=PASTE_YOUR_BOT_TOKEN_HERE
DISCORD_USER_ID=USER_ID_1,USER_ID_2  # Supports multiple IDs separated by commas
TURNSTILE_SECRET_KEY=PASTE_YOUR_SECRET_KEY_HERE
