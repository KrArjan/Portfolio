# Local dev secrets — mirrors Cloudflare environment variables
# Copy this file to .dev.vars and fill in your values
# DO NOT commit .dev.vars to git

# ── Discord Webhook (Required for contact form) ──────────────
# Get this from: Discord Server → Channel Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=PASTE_YOUR_WEBHOOK_URL_HERE

# ── Discord Bot DM (Optional — sends DMs to you) ─────────────
# Create a bot at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=PASTE_YOUR_BOT_TOKEN_HERE
DISCORD_USER_ID=PASTE_YOUR_USER_ID_HERE

# ── Cloudflare Turnstile (Required for contact form) ─────────
# Get this from: https://dash.cloudflare.com → Turnstile
TURNSTILE_SITE_KEY=PASTE_YOUR_SITE_KEY_HERE
TURNSTILE_SECRET_KEY=PASTE_YOUR_SECRET_KEY_HERE

# ── EmailJS (Optional — sends email copies) ──────────────────
# Set up at: https://www.emailjs.com
EMAILJS_SERVICE_ID=PASTE_YOUR_SERVICE_ID_HERE
EMAILJS_TEMPLATE_ID=PASTE_YOUR_TEMPLATE_ID_HERE
EMAILJS_PUBLIC_KEY=PASTE_YOUR_PUBLIC_KEY_HERE
EMAILJS_PRIVATE_KEY=PASTE_YOUR_PRIVATE_KEY_HERE
